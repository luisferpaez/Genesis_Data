// --- FUNCIONES DE SEGURIDAD Y ESPEJO ---
void OnTick() {
   // 1. DESCARGA: El Slave lee la realidad de Génesis desde tu repo 'Genesis_Data'
   string json_data = PullFromGitHub(); 
   
   // 2. LATIDO (HEARTBEAT): Si el Master no se reporta en 5 min, modo preventivo
   datetime last_heart = ExtractHeartbeat(json_data);
   if(TimeCurrent() - last_heart > 300) { 
      Print("ALERTA: Master (Génesis) desconectado. No se abren nuevas órdenes.");
      return; 
   }

   // 3. ESPEJO (CIERRE POR AUSENCIA): La clave de tu seguridad
   for(int i = PositionsTotal() - 1; i >= 0; i--) {
      ulong slave_ticket = PositionGetTicket(i);
      // Usamos el Magic Number para saber qué ticket de Génesis representa esta orden
      long master_ref = PositionGetInteger(POSITION_MAGIC); 

      // Si tú cerraste en Génesis (manual o bot), ya no estará en el JSON
      if(!EstaEnInventarioGitHub(master_ref, json_data)) {
         trade.PositionClose(slave_ticket); // El Slave la cierra de inmediato
         Print("Sincronización: Orden cerrada en Master, replicando en Slave Demo.");
      }
   }
   
   // 4. NUEVAS ÓRDENES: Solo si el Master está en "ACTIVE"
   if(ExtractAllowTrades(json_data)) {
      // Aquí el Slave abre las órdenes nuevas que vea en el JSON
      EjecutarCopiaNuevas(json_data);
   }
}
